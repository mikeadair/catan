rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function room(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data;
    }

    function isMember(roomId) {
      return signedIn() && request.auth.uid in room(roomId).turnOrder;
    }

    function isHost(roomId) {
      return signedIn() && request.auth.uid == room(roomId).hostUid;
    }

    match /rooms/{roomId} {
      // Anyone signed in who is already a member can read; anyone signed in can also read
      // a still-open lobby, so joining-by-code can validate the room before the join write.
      allow read: if signedIn() && (request.auth.uid in resource.data.turnOrder || resource.data.status == 'lobby');

      // Creation: any signed-in user may create a room doc for themselves as host (this is
      // how createRoom's initial writeBatch succeeds before they're a "member" of anything).
      allow create: if signedIn() && request.auth.uid == request.resource.data.hostUid;

      // Updates: lobby-management only (join/leave/add-bot/house-rules edits by a seated
      // member, or a non-member's own self-join write). Once a game is 'playing', all
      // mutation goes through the submitAction/startGame Cloud Functions instead (Admin SDK,
      // bypasses these rules entirely) — no direct client write to the room doc is ever
      // legitimate past that point. (The host is always in turnOrder by construction, so a
      // separate host-only clause here would be redundant with the member clause below.)
      allow update: if signedIn() && resource.data.status == 'lobby' && (
        request.auth.uid in resource.data.turnOrder ||
        (
          request.auth.uid in request.resource.data.turnOrder &&
          !(request.auth.uid in resource.data.turnOrder)
        )
      );

      // Only the sole remaining seat, leaving a still-open lobby, may delete the room —
      // this is removeSeat's "last one out" case (see web/src/firebase/rooms.ts): nothing
      // left to host once they're gone, so the room doc itself gets cleaned up instead of
      // orphaned. Never legal once a game has actually started.
      allow delete: if signedIn() && resource.data.status == 'lobby'
        && resource.data.turnOrder.size() == 1
        && request.auth.uid in resource.data.turnOrder;
    }

    match /rooms/{roomId}/players/{uid} {
      // Members can always read (mid-game too). Non-members can also read while the room
      // is still 'lobby' — joinRoom's assignSeat needs to read every already-seated
      // player's doc (to know which seats/colors are taken) before the joiner themselves
      // is a member, and there's nothing sensitive in a lobby-phase public player doc
      // anyway (name/color/seat/bot-difficulty).
      allow read: if isMember(roomId) || (signedIn() && room(roomId).status == 'lobby');

      // Host-driven bot seat management (add/kick a bot) always happens on an
      // already-existing room, so reading room(roomId) here is safe. Self-writes to your
      // OWN seat deliberately do NOT read room(roomId) at all (see below) — createRoom
      // creates the room doc and the host's own player doc in the SAME atomic batch, so at
      // the moment this rule evaluates for that player-doc write, the room doc doesn't
      // exist yet from the rules engine's point of view and get() would deny the write.
      function isHostManagingBot() {
        return isHost(roomId) && room(roomId).status == 'lobby' && (
          (request.resource != null && request.resource.data.isBot == true) ||
          (resource != null && resource.data.isBot == true)
        );
      }

      // Self-managing your own seat (create at join/create-room time, delete at leave
      // time) is unconditional on room status, same as before this file's rewrite — no
      // room-doc read needed, which sidesteps the create-time chicken-and-egg above.
      allow create, delete: if signedIn() && (request.auth.uid == uid || isHostManagingBot());

      allow update: if signedIn() && (
        (request.auth.uid == uid && room(roomId).status == 'lobby') ||
        isHostManagingBot() ||
        (
          request.auth.uid == uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['connected', 'lastSeen'])
        )
      );

      match /private/hand {
        // A player's own hand is private to them, both to read and write. One necessary
        // extension: bot hands have no real auth principal behind them, so any room member
        // may read a hand doc whose parent player doc is a bot — needed for whichever
        // client's UI layer decides a bot's move (decideBotAction) to see its hand before
        // submitting the resulting action for the server to apply.
        //
        // Write is unconditionally denied: every hand mutation (dealing at game start,
        // building, trading, discarding, ...) now goes through the startGame/submitAction
        // Cloud Functions (Admin SDK, bypasses this rule), never a direct client write.
        function parentIsBot() {
          return get(/databases/$(database)/documents/rooms/$(roomId)/players/$(uid)).data.isBot == true;
        }

        allow read: if signedIn() && (request.auth.uid == uid || (isMember(roomId) && parentIsBot()));
        allow write: if false;
      }
    }

    // The real dev-card draw order (and any other future server-only secrets). Never
    // client-readable or -writable — only the submitAction/startGame Cloud Functions (Admin
    // SDK, bypasses these rules) ever touch this collection. Clients see the public,
    // client-safe devCardDeckCount mirror on the room doc instead.
    match /rooms/{roomId}/serverOnly/{document=**} {
      allow read, write: if false;
    }

    match /rooms/{roomId}/trades/{tradeId} {
      allow read: if isMember(roomId);

      // All trade mutation (propose/accept/reject/cancel/counter, including on behalf of a
      // bot) now goes through submitAction (Admin SDK, bypasses these rules).
      allow create, update: if false;
      allow delete: if false;
    }

    match /rooms/{roomId}/chat/{msgId} {
      allow read: if isMember(roomId);
      allow create: if isMember(roomId) && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;
    }

    // Per-account preference doc (display name + preferred color), written once a guest
    // upgrades to a real (email) account — see web/src/firebase/users.ts. Strictly own-doc
    // only, both directions; nobody else may read or write another uid's preferences.
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }
  }
}
