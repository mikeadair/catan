{
  "name": "functions",
  "version": "0.0.0",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run typecheck && esbuild src/index.ts --bundle --platform=node --target=node22 --format=cjs --outfile=lib/index.js --external:firebase-admin --external:firebase-functions",
    "test": "vitest run",
    "serve": "npm run build && firebase emulators:start --only functions,firestore,auth",
    "build:e2e-bridge": "esbuild src/e2eBridge.ts --bundle --platform=node --target=node22 --format=cjs --outfile=lib/e2eBridge.js --external:firebase-admin --external:firebase-functions",
    "e2e-bridge": "npm run build:e2e-bridge && node lib/e2eBridge.js"
  },
  "dependencies": {
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "firebase-functions-test": "^3.5.0",
    "nanoid": "^5.1.16",
    "typescript": "~6.0.2",
    "vitest": "^4.1.10"
  }
}
